<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Mini Jogo</title>
</head>
<body>

  <h2>Jogo: Adivinhe o número (1 a 20)</h2>

  <input type="number" id="numero">
  <button onclick="tentar()">Tentar</button>
  <button onclick="reiniciar()">Reiniciar</button>

  <p id="mensagem"></p>
  <p id="tentativas"></p>

  <script>
    
    let numeroSecreto = Math.floor(Math.random() * 20) + 1;
    let contador = 0;

    
    function tentar() {
      let chute = Number(document.getElementById("numero").value);

      contador++;

      
      if (chute > numeroSecreto) {
        document.getElementById("mensagem").innerText = "Muito alto";
      } 
      else if (chute < numeroSecreto) {
        document.getElementById("mensagem").innerText = "Muito baixo";
      } 
      else {
        document.getElementById("mensagem").innerText = "Acertou!";
      }

      document.getElementById("tentativas").innerText = 
        "Tentativas: " + contador;
    }
    
    function reiniciar() {
     
      while (true) {
        numeroSecreto = Math.floor(Math.random() * 20) + 1;
        contador = 0;
        break;
      }

      document.getElementById("mensagem").innerText = "";
      document.getElementById("tentativas").innerText = "";
      document.getElementById("numero").value = "";
    }
  </script>

</body>
</html>
