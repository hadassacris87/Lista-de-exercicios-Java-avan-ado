<html>
<body>

<h2>Professor Automatizado</h2>

<form onsubmit="return verificar()">

  <input type="number" id="nota1" placeholder="Nota 1">
  <input type="number" id="nota2" placeholder="Nota 2">

  <button type="submit">Calcular Média</button>

</form>

<p id="resultado"></p>

<script>
function verificar() {

  
  var n1 = Number(document.getElementById("nota1").value);
  var n2 = Number(document.getElementById("nota2").value);
  var resultado = document.getElementById("resultado");


  if (n1 == "" || n2 == "") {
    resultado.innerHTML = "Digite as duas notas";
    resultado.style.color = "black";
    return false;
  }


  var media = (n1 + n2) / 2;

  
  if (media >= 7) {
    resultado.innerHTML = "Aprovado - Média: " + media;
    resultado.style.color = "green";
  } else if (media >= 5) {
    resultado.innerHTML = "Recuperação - Média: " + media;
    resultado.style.color = "orange";
  } else {
    resultado.innerHTML = "Reprovado - Média: " + media;
    resultado.style.color = "red";
  }

  return false;
}
</script>

</body>
</html>
